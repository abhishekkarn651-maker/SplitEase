# ========================================
# SplitEase — Environment Variables
# ========================================
# Copy this file to .env and fill in your values.

# MongoDB connection string
# For local MongoDB: mongodb://localhost:27017/splitease
# For MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.xxxxx.mongodb.net/splitease
MONGO_URI=mongodb://localhost:27017/splitease

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
